{
    "services": {
        "frontend": {
            "source": "frontend",
            "routePrefix": "/",
            "build": {
                "builder": "NIXPACKS"
            },
            "deploy": {
                "startCommand": "npm run start",
                "healthcheckPath": "/"
            }
        },
        "backend": {
            "source": "backend",
            "routePrefix": "/api",
            "build": {
                "builder": "NIXPACKS"
            },
            "deploy": {
                "startCommand": "npm start",
                "healthcheckPath": "/api/health"
            }
        }
    }
}
